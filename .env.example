ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here           # optional

RECUT_DB_PATH=~/.recut/recut.db        # default local SQLite path
RECUT_DEFAULT_LANGUAGE=simple          # simple | power

RECUT_FLAG_THRESHOLD_LOW=0.4
RECUT_FLAG_THRESHOLD_MEDIUM=0.65
RECUT_FLAG_THRESHOLD_HIGH=0.85

RECUT_META_MODEL=claude-haiku-4-5-20251001   # cheap model for flagging
RECUT_USE_EMBEDDINGS=true              # enable layer 2 embedding similarity
RECUT_EMBEDDING_THRESHOLD=0.75         # cosine similarity threshold
RECUT_LOCAL_MODEL=                     # optional ollama model for layer 4

RECUT_CACHE_ENABLED=true
RECUT_CACHE_TTL=3600                   # seconds, default 1 hour

RECUT_DEFAULT_SAMPLE_RATE=1.0          # 1.0 = always trace, 0.1 = 10% of runs
RECUT_TOKEN_BUDGET=0                   # warn above this per session (0 = no limit)
